# ============================================================
# Python cache
# ============================================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ipynb_checkpoints/

# ============================================================
# Virtual environment
# ============================================================
.venv/
venv/
env/
ENV/

# ============================================================
# IDE / Editor
# ============================================================
.vscode/
.idea/

# ============================================================
# OS files
# ============================================================
.DS_Store
Thumbs.db

# ============================================================
# Streamlit / Secrets
# ============================================================
.streamlit/secrets.toml
.env
.env.*
*.key
*.pem

# ============================================================
# Logs / Temporary files
# ============================================================
*.log
logs/
tmp/
temp/
*.tmp

# ============================================================
# Data files - không push dữ liệu lớn lên GitHub
# ============================================================
data/raw/*.csv
data/processed/*.csv
data/output/*.csv
data/neo4j/*.csv

# Giữ cấu trúc thư mục trên GitHub
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/output/.gitkeep
!data/neo4j/.gitkeep

# ============================================================
# Large compressed files
# ============================================================
*.zip
*.rar
*.7z
*.tar
*.gz
